# MongoDB Atlas — get from https://cloud.mongodb.com
MONGODB_URI="mongodb+srv://USER:PASS@cluster.xxxxx.mongodb.net/aimeeting?retryWrites=true&w=majority"

# Groq — get from https://console.groq.com/keys (used for fast Whisper transcription)
GROQ_API_KEY="gsk_..."

# OpenAI — get from https://platform.openai.com/api-keys (used for diarization + summary)
OPENAI_API_KEY="sk-proj-..."

# Resend — get from https://resend.com/api-keys (used to send follow-up emails)
RESEND_API_KEY="re_..."

# Email "from" address — must be on a verified Resend domain (or "onboarding@resend.dev" for testing)
RESEND_FROM="AI Meeting <onboarding@resend.dev>"
